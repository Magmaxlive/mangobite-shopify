    "mango_variety_info_Hbg7mD": {
      "type": "mango-variety-info",
      "blocks": {
        "info_tab_C4H7rH": {
          "type": "info_tab",
          "settings": {
            "icon": "shopify://shop_images/p-icon-41.png",
            "label": "Also known as",
            "content": "<p>Safedi , Kesar is commonly also called the Queen of Mangoes.</p>"
          }
        },
        "info_tab_XUH3cV": {
          "type": "info_tab",
          "settings": {
            "icon": "shopify://shop_images/p-icon-2png.png",
            "label": "Origin",
            "content": "<p>(Western India) This is a famous variety of Saurashtra region of Gujarat. Grown in and around Ahmedabad, Gujarat, these are used primarily to make aamras in Gujarat.</p>"
          }
        },
        "info_tab_GLRJHB": {
          "type": "info_tab",
          "settings": {
            "icon": "shopify://shop_images/p-icon-5.png",
            "label": "Season",
            "content": "<p>June to Early July.</p>"
          }
        },
        "info_tab_6dr9GL": {
          "type": "info_tab",
          "settings": {
            "icon": "shopify://shop_images/icon-4png3.png",
            "label": "Shape",
            "content": "<p>Kesar is a small to medium fruit with a roundish shape and a distinct curved tip.</p>"
          }
        },
        "info_tab_QyYFiN": {
          "type": "info_tab",
          "settings": {
            "icon": "shopify://shop_images/p-icon-1png.png",
            "label": "Taste & Texture",
            "content": "<p>A deep yellow-orange flesh, smooth and fragrant with intense sweetness.</p>"
          }
        },
        "info_tab_zKxrWf": {
          "type": "info_tab",
          "settings": {
            "icon": "shopify://shop_images/icon-6_1.png",
            "label": "Other Characteristics",
            "content": "<p>• Skin is edible.<br/>• Mostly used to make preservatives.<br/>• Fruits are medium sized.<br/>• Flesh is sweet and fibreless.<br/>• It has excellent sugar-acid blend.<br/>• Fruits ripen to attractive apricot-yellow colour with a red blush.<br/>• It has good processing quality.<br/>• Its smell is its most distinguishing feature.<br/>• The colour of the pulp resembling saffron, the spice it is named after.<br/>• The skin is greener than most other mangoes.<br/></p>"
          }
        },
        "info_tab_Wet6qk": {
          "type": "info_tab",
          "settings": {
            "icon": "shopify://shop_images/p-icon-6.png",
            "label": "Weight",
            "content": "<p>These mangoes are medium sized, weighing on an average 225-250 grams.</p>"
          }
        }
      },
