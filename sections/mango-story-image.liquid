{{ 'section-mango-story-image.css' | asset_url | stylesheet_tag }}

<section class="mango-story-image" style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">

  {%- if section.settings.image != blank -%}
    {%- assign img_style = 'max-width: ' | append: section.settings.image_max_width | append: 'px' -%}
    <div class="mango-story-image__wrap">
      {{
        section.settings.image
        | image_url: width: 800
        | image_tag: loading: 'lazy', alt: '', style: img_style
      }}
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Mango Story Image",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Center image"
    },
    {
      "type": "range",
      "id": "image_max_width",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Image max width",
      "default": 460
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Mango Story Image"
    }
  ]
}
{% endschema %}
