{{ 'section-mango-story-banner.css' | asset_url | stylesheet_tag }}

<section class="mango-story-banner" style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">

  {%- if section.settings.left_leaf != blank -%}
    <div class="mango-story-banner__leaf mango-story-banner__leaf--left">
      {{
        section.settings.left_leaf
        | image_url: width: 600
        | image_tag: loading: 'eager', alt: ''
      }}
    </div>
  {%- endif -%}

  {%- if section.settings.right_leaf != blank -%}
    <div class="mango-story-banner__leaf mango-story-banner__leaf--right">
      {{
        section.settings.right_leaf
        | image_url: width: 600
        | image_tag: loading: 'eager', alt: ''
      }}
    </div>
  {%- endif -%}

  <div class="mango-story-banner__inner">

    {%- if section.settings.subtitle != blank -%}
      <p class="mango-story-banner__subtitle" style="color: {{ section.settings.subtitle_color }};">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="mango-story-banner__heading" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="mango-story-banner__description" style="color: {{ section.settings.description_color }};">{{ section.settings.description }}</p>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "Mango Story Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "MY MANGO STORY"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Grab Your Snack Time Essential - Mango Bite!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description (optional)"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#aaaaaa"
    },
    {
      "type": "header",
      "content": "Leaf decorations"
    },
    {
      "type": "image_picker",
      "id": "left_leaf",
      "label": "Top-left leaf"
    },
    {
      "type": "image_picker",
      "id": "right_leaf",
      "label": "Top-right leaf"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#888888"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 160
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Mango Story Banner"
    }
  ]
}
{% endschema %}
