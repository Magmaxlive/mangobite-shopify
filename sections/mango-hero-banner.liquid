{{ 'section-mango-hero-banner.css' | asset_url | stylesheet_tag }}

<div class="mango-hero-banner-wrap">
<section
  class="mango-hero-banner"
  style="min-height: {{ section.settings.min_height }}px; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>

  {%- if section.settings.bg_image != blank -%}
    <div class="mango-hero-banner__bg">
      {{
        section.settings.bg_image
        | image_url: width: 1800
        | image_tag: loading: 'eager', alt: '', class: 'mango-hero-banner__bg-img'
      }}
    </div>
  {%- endif -%}

  {%- if section.settings.top_left_deco != blank -%}
    <div class="mango-hero-banner__deco mango-hero-banner__deco--top-left">
      {{ section.settings.top_left_deco | image_url: width: 500 | image_tag: loading: 'eager', alt: '' }}
    </div>
  {%- endif -%}

  {%- if section.settings.top_right_leaf != blank -%}
    <div class="mango-hero-banner__deco mango-hero-banner__deco--top-right">
      {{ section.settings.top_right_leaf | image_url: width: 400 | image_tag: loading: 'eager', alt: '' }}
    </div>
  {%- endif -%}

  {%- if section.settings.bottom_left_leaf != blank -%}
    <div class="mango-hero-banner__deco mango-hero-banner__deco--bottom-left">
      {{ section.settings.bottom_left_leaf | image_url: width: 400 | image_tag: loading: 'eager', alt: '' }}
    </div>
  {%- endif -%}

  {%- if section.settings.bottom_right_leaf != blank -%}
    <div class="mango-hero-banner__deco mango-hero-banner__deco--bottom-right">
      {{ section.settings.bottom_right_leaf | image_url: width: 400 | image_tag: loading: 'eager', alt: '' }}
    </div>
  {%- endif -%}

  <div class="mango-hero-banner__content page-width">
    <div class="mango-hero-banner__text">

      {%- if section.settings.subtitle != blank -%}
        <p class="mango-hero-banner__subtitle" style="color: {{ section.settings.subtitle_color }};">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="mango-hero-banner__heading" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="mango-hero-banner__description" style="color: {{ section.settings.text_color }};">
          {{ section.settings.description }}
        </p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="mango-hero-banner__btn"
          style="color: {{ section.settings.btn_color }}; border-bottom-color: {{ section.settings.btn_underline_color }};"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}

    </div>
  </div>

</section>
</div>

{% schema %}
{
  "name": "Mango Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "MANGO BITE"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Savor the Juicy Goodness of Mango Bite!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "One of the finest mangoes of South India is the hugely popular banganapalli mango grown extensively in Andhra Pradesh and Telangana."
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description color",
      "default": "#dddddd"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_underline_color",
      "label": "Button underline color",
      "default": "#C8922A"
    },
    {
      "type": "header",
      "content": "Decorations"
    },
    {
      "type": "image_picker",
      "id": "top_left_deco",
      "label": "Top-left decoration"
    },
    {
      "type": "image_picker",
      "id": "top_right_leaf",
      "label": "Top-right leaf"
    },
    {
      "type": "image_picker",
      "id": "bottom_left_leaf",
      "label": "Bottom-left leaf"
    },
    {
      "type": "image_picker",
      "id": "bottom_right_leaf",
      "label": "Bottom-right leaf"
    },
    {
      "type": "header",
      "content": "Sizing"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 300,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Minimum height",
      "default": 600
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Mango Hero Banner"
    }
  ]
}
{% endschema %}
