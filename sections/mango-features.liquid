{{ 'section-mango-features.css' | asset_url | stylesheet_tag }}

<section
  class="mango-features"
  style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="mango-features__inner page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="mango-features__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="mango-features__grid">
      {%- for block in section.blocks -%}
        <div class="mango-features__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="mango-features__icon" style="background-color: {{ section.settings.icon_bg_color }};">
              {{
                block.settings.image
                | image_url: width: 300
                | image_tag: loading: 'lazy', alt: block.settings.title
              }}
            </div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <p class="mango-features__title">{{ block.settings.title }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Mango Features",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon blob color",
      "default": "#E8C89A"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mango Features",
      "blocks": [
        { "type": "feature", "settings": { "title": "100% Organic Mangoes" } },
        { "type": "feature", "settings": { "title": "Delicious & Pulpy" } },
        { "type": "feature", "settings": { "title": "All Over NZ Delivery" } },
        { "type": "feature", "settings": { "title": "Varieties of Mangoes" } },
        { "type": "feature", "settings": { "title": "Directly From Farmers" } },
        { "type": "feature", "settings": { "title": "Carbide & Chemical Free" } }
      ]
    }
  ]
}
{% endschema %}
