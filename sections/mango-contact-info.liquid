{{ 'section-mango-contact-info.css' | asset_url | stylesheet_tag }}

<section
  class="mango-contact-info"
  style="
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="mango-contact-info__container">

    <!-- Contact + Reach Us -->
    <div class="mango-contact-info__top">

      <!-- Contact -->
      <div class="mango-contact-info__col">
        {%- if section.settings.contact_heading != blank -%}
          <h2 class="mango-contact-info__col-heading">{{ section.settings.contact_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.address != blank -%}
          <p class="mango-contact-info__address">{{ section.settings.address | newline_to_br }}</p>
        {%- endif -%}
      </div>

      <!-- Reach Us -->
      <div class="mango-contact-info__col">
        {%- if section.settings.reach_heading != blank -%}
          <h2 class="mango-contact-info__col-heading">{{ section.settings.reach_heading }}</h2>
        {%- endif -%}
        <ul class="mango-contact-info__reach-list">
          {%- if section.settings.phone != blank -%}
            <li class="mango-contact-info__reach-item">
              <span class="mango-contact-info__reach-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.4 2 2 0 0 1 3.59 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </span>
              <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone }}</a>
            </li>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <li class="mango-contact-info__reach-item">
              <span class="mango-contact-info__reach-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </span>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
            </li>
          {%- endif -%}
        </ul>
      </div>

    </div>

    <!-- Follow Us -->
    {%- if section.settings.social_heading != blank
        or section.settings.facebook_url != blank
        or section.settings.instagram_url != blank -%}
      <div class="mango-contact-info__social">
        {%- if section.settings.social_heading != blank -%}
          <h2 class="mango-contact-info__social-heading">{{ section.settings.social_heading }}</h2>
        {%- endif -%}
        <div class="mango-contact-info__social-links">
          {%- if section.settings.facebook_url != blank -%}
            <a
              class="mango-contact-info__social-link"
              href="{{ section.settings.facebook_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
            >
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.791-4.697 4.533-4.697 1.313 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.268h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
              </svg>
              Facebook
            </a>
          {%- endif -%}
          {%- if section.settings.instagram_url != blank -%}
            <a
              class="mango-contact-info__social-link"
              href="{{ section.settings.instagram_url }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Instagram
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

  </div>

  <!-- Map -->
  {%- if section.settings.map_embed_url != blank -%}
    <div class="mango-contact-info__map">
      <iframe
        src="{{ section.settings.map_embed_url }}"
        height="{{ section.settings.map_height }}"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Store location map"
      ></iframe>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Mango Contact Info",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Contact column"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Heading",
      "default": "Contact"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "102 White Swan Road, Mount Roskill,\nNew Zealand"
    },
    {
      "type": "header",
      "content": "Reach Us column"
    },
    {
      "type": "text",
      "id": "reach_heading",
      "label": "Heading",
      "default": "Reach us"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "02 772 24561"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "info@mangobite.co.nz"
    },
    {
      "type": "header",
      "content": "Follow Us"
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Heading",
      "default": "Follow Us"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "header",
      "content": "Google Maps"
    },
    {
      "type": "text",
      "id": "map_embed_url",
      "label": "Google Maps embed URL",
      "info": "In Google Maps, click Share → Embed a map → copy the src URL from the iframe code."
    },
    {
      "type": "range",
      "id": "map_height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Map height",
      "default": 480
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Mango Contact Info",
      "settings": {
        "contact_heading": "Contact",
        "address": "102 White Swan Road, Mount Roskill,\nNew Zealand",
        "reach_heading": "Reach us",
        "phone": "02 772 24561",
        "email": "info@mangobite.co.nz",
        "social_heading": "Follow Us"
      }
    }
  ]
}
{% endschema %}
