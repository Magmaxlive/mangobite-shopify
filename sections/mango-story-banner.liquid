{{ 'section-mango-story-banner.css' | asset_url | stylesheet_tag }}

<section class="mango-story-banner" style="background-color: {{ section.settings.bg_color }}; min-height: {{ section.settings.section_height }}px;">

  {%- if section.settings.left_leaf != blank -%}
    <div class="mango-story-banner__leaf mango-story-banner__leaf--left">
      {{
        section.settings.left_leaf
        | image_url: width: 600
        | image_tag: loading: 'eager', alt: ''
      }}
    </div>
  {%- endif -%}

  {%- if section.settings.right_leaf != blank -%}
    <div class="mango-story-banner__leaf mango-story-banner__leaf--right">
      {{
        section.settings.right_leaf
        | image_url: width: 600
        | image_tag: loading: 'eager', alt: ''
      }}
    </div>
  {%- endif -%}

  <div class="mango-story-banner__inner page-width">

    {%- if section.settings.subtitle != blank -%}
      <p class="mango-story-banner__subtitle" style="color: {{ section.settings.subtitle_color }};">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="mango-story-banner__heading" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.hero_image != blank -%}
      <div class="mango-story-banner__image">
        {{
          section.settings.hero_image
          | image_url: width: 800
          | image_tag: loading: 'eager', alt: section.settings.heading
        }}
      </div>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "Mango Story Banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "MY MANGO STORY"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Grab Your Snack Time Essential - Mango Bite!"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Center hero image"
    },
    {
      "type": "header",
      "content": "Leaf decorations"
    },
    {
      "type": "image_picker",
      "id": "left_leaf",
      "label": "Top-left leaf"
    },
    {
      "type": "image_picker",
      "id": "right_leaf",
      "label": "Top-right leaf"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#888888"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Section height",
      "default": 700
    }
  ],
  "presets": [
    {
      "name": "Mango Story Banner"
    }
  ]
}
{% endschema %}
